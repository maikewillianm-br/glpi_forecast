# Copie para .env e preencha (não commite o .env)

CLICKHOUSE_HOST=10.123.17.2
CLICKHOUSE_HTTP_PORT=8123
CLICKHOUSE_USER=xxxxxx
CLICKHOUSE_PASSWORD=xxxxx
CLICKHOUSE_DATABASE=_master

# Tabela e coluna de data para agregação diária (ajuste ao schema real no ClickHouse)
GLPI_EVENTS_TABLE=glpi_tickets
GLPI_DATE_COLUMN=date

# Janela opcional (YYYY-MM-DD); vazio = sem filtro extra de datas
GLPI_DATE_FROM=
GLPI_DATE_TO=

# Modelagem
TRAIN_RATIO=0.75
ARIMA_ORDER=1,1,1
FORECAST_HORIZON=14
